# Tatum Sui RPC (get a free key at https://tatum.io)
NEXT_PUBLIC_TATUM_SUI_TESTNET_RPC=https://api.tatum.io/v3/blockchain/node/sui-testnet/<YOUR_TATUM_API_KEY>

# Published Sui Move package address (filled in after `sui client publish`)
NEXT_PUBLIC_RECEIPT_PACKAGE_ID=0x0

# Snapshotter service base URL (local dev: http://localhost:8080)
NEXT_PUBLIC_SNAPSHOTTER_URL=http://localhost:8080

# Walrus testnet aggregator (for client-side blob fetches in verifier)
NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
