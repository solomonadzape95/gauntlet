# Tatum Sui Testnet RPC (get a free key at https://tatum.io)
# IMPORTANT: server-only — the browser calls /api/sui-rpc which forwards here.
# (Was NEXT_PUBLIC_TATUM_SUI_TESTNET_RPC; that still works for backward compat
# but exposes the key to the browser bundle.)
TATUM_SUI_TESTNET_RPC=https://api.tatum.io/v3/blockchain/node/sui-testnet/<YOUR_TATUM_API_KEY>

# Tatum REST base for Data API queries (server-side calls)
TATUM_API_KEY=<YOUR_TATUM_API_KEY>
TATUM_API_BASE=https://api.tatum.io/v4

# Published Sui Move package (filled in after `sui client publish`)
NEXT_PUBLIC_GAUNTLET_PACKAGE_ID=0x0

# Shared Pool object (filled in after calling create_pool)
NEXT_PUBLIC_POOL_OBJECT_ID=0x0

# Pool admin wallet (gates the /admin route in the UI)
NEXT_PUBLIC_ADMIN_ADDRESS=0x0

# Walrus testnet
NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space

# Walrus blob ids (filled in after uploading data/*.json)
NEXT_PUBLIC_ROSTER_BLOB_ID=
NEXT_PUBLIC_MATCHDAY_BLOB_ID=

# Discord webhook for Tatum Notifications → push pings (Day 4)
# Server route /api/notify/tatum receives Tatum payloads and forwards them here.
DISCORD_WEBHOOK_URL=

# (Optional) Shared secret echoed by Tatum in the X-Notify-Secret header.
# When set, /api/notify/tatum rejects requests without a matching header.
TATUM_NOTIFY_SECRET=

# Google Gemini API key for the AI Broker chat panel (Day 4) + the
# seed-roster script (Day 5). Get one at https://aistudio.google.com/apikey.
# If unset, the AI Broker serves a templated reply and the seed script
# falls back to deterministic targets.
GEMINI_API_KEY=

# API-Football REST key (Day 5). Free tier: 100 req/day at
# dashboard.api-football.com. Used only by scripts/seed-roster.ts —
# never sent to the browser. Cached per-endpoint under data/.cache/.
API_FOOTBALL_KEY=
